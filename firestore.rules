rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Board items ────────────────────────────────────────────────────────
    // Collaborative mode: anyone with the link can read and draw.
    // No login required to participate — that is by design.
    match /boards/{boardId}/items/{itemId} {
      allow read, write: if true;
    }

    // ── Board metadata ─────────────────────────────────────────────────────
    // Anyone can read (needed to fetch title when joining via link).
    // Anyone can create (anonymous boards are allowed).
    // Only authenticated users can update / delete their own boards.
    match /boards/{boardId} {
      allow read: if true;
      allow create: if true;
      allow update: if request.auth != null;
      allow delete: if request.auth != null
                    && resource.data.createdBy == request.auth.uid;
    }

    // ── Invites ────────────────────────────────────────────────────────────
    // Only authenticated users can send or read invitations.
    match /invites/{inviteId} {
      allow read, write: if request.auth != null;
    }
  }
}
